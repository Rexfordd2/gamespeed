# GameSpeed — environment variables
#
# Copy this file to `.env.local` for local development.
# In Vercel, add the same variables in Project Settings -> Environment Variables
# (set for Production + Preview + Development environments).
#
# IMPORTANT: You must also add your app URLs to the Supabase redirect allowlist.
# Supabase Dashboard -> Authentication -> URL Configuration -> Redirect URLs:
#   - http://localhost:5173          (local dev)
#   - https://<your-app>.vercel.app  (production)
# Without these, magic-link sign-in will not work.

# Supabase public project URL  (Dashboard -> Settings -> API -> Project URL)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase public anon key (safe for browser clients)  (Dashboard -> Settings -> API -> anon public key)
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Optional: explicit app environment label (defaults to Vite mode)
# Example values: local, preview, production
VITE_APP_ENV=

# Optional: force landing experiment variant (A, B, or C).
# Leave unset for deterministic auto-assignment per browser.
VITE_LANDING_EXPERIMENT_VARIANT=
